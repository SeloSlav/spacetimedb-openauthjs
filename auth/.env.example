# Copy this to .env and fill in your values
NODE_ENV=development
PORT=4001
ISSUER_URL=http://localhost:4001

# For production, set DATABASE_URL to your PostgreSQL connection string
# DATABASE_URL=postgresql://user:pass@host:port/dbname

# Generate JWT keys using: node generate-keys.js
JWT_PRIVATE_KEY=your_private_key_here
JWT_PUBLIC_KEY=your_public_key_here

# Password reset email settings (AUTH SERVER ONLY)
# Required to send forgot-password emails via Resend.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Sender identity (must be a verified sender/domain in Resend)
# Example: SpacetimeDB Auth Demo <noreply@yourdomain.com>
RESEND_FROM=SpacetimeDB Auth Demo <noreply@example.com>